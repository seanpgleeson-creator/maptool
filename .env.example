# Set these in Vercel Environment Variables for production.

# Postgres connection string (phase 2)
DATABASE_URL=

# LLM for policy analysis (OpenAI or compatible)
OPENAI_API_KEY=

# Object storage: Vercel Blob token, or leave empty if using S3/AWS later
BLOB_READ_WRITE_TOKEN=

# Optional: Walmart price lookup via UPCitemdb (Option D hybrid). ScrapingDog fetches UPCitemdb page; we parse Walmart price/link.
# ScrapingDog: https://www.scrapingdog.com/ — get API key from dashboard. Set for Production (and Preview) in Vercel, then redeploy.
# SCRAPINGDOG_API_KEY=
